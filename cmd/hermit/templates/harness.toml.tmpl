[github]
owner                = "{{ .Owner }}"
repo                 = "{{ .Repo }}"
rate_limit_threshold = 10
default_branch       = "develop"

[agent]
max_engineers = {{ .MaxEngineers }}
language      = "{{ .Language }}"
# loop_interval    = 270      # Superintendent cycle interval in seconds (default: 270)
# trigger_comment  = "/hermit"  # Only process Issues that have a comment containing this string

[model]
superintendent = "{{ .SuperintendentModel }}"
engineer       = "{{ .EngineerModel }}"
analyst        = "{{ .AnalystModel }}"  # Analyst (PM): human requirements -> REQ-ID formatted requirements doc
{{- if .SuperintendentEffort }}
superintendent_effort = "{{ .SuperintendentEffort }}"  # reasoning effort: low/medium/high/xhigh/max
{{- end }}
{{- if .EngineerEffort }}
engineer_effort       = "{{ .EngineerEffort }}"  # reasoning effort: low/medium/high/xhigh/max
{{- end }}
{{- if .AnalystEffort }}
analyst_effort         = "{{ .AnalystEffort }}"  # reasoning effort: low/medium/high/xhigh/max
{{- end }}

# branch_prefix = "hermit/your-login"  # defaults to hermit/<gh_login> if omitted

# [readiness]
# min_body_length                 = 40                    # minimum non-whitespace chars in the Issue body
# skip_acceptance_criteria_check  = false                  # if true, don't require an "Acceptance Criteria" / "受け入れ条件" section
# label                           = "needs-clarification"  # label applied to Issues judged not ready; also excludes them from list_issues

# [notification]
# webhook_url = "https://hooks.slack.com/services/..."  # Slack, Discord, or generic webhook
# type        = "slack"  # "slack" | "discord" | "generic" (auto-detected from URL if omitted)

# [requirements]
# doc          = "REQUIREMENTS.md"  # requirements doc parsed for "## REQ-xxx:" blocks (default shown)
# # test_command must produce `go test -v` style output ("=== RUN" markers)
# # so the sweep can tell "no such test" apart from "test failed".
# test_command = "go test ./... -run '^{req_id}' -v"
